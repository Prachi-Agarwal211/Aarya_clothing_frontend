# Aarya Clothing - Environment Configuration Template
# Copy this file to .env and fill in your values

# ==================== Environment ====================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ==================== Database ====================
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://postgres:your_secure_password_here@postgres:5432/aarya_clothing

# ==================== Redis ====================
# Redis connection URL with password (format: redis://:password@host:port/db)
REDIS_URL=redis://:your_redis_password_here@redis:6379/0
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# ==================== Security ====================
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here

# ==================== Token Settings ====================
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440
SESSION_EXPIRE_MINUTES=1440

# ==================== Password Policy ====================
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=false

# ==================== Rate Limiting ====================
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=300
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30

# ==================== Business Configuration ====================
# Seller's registered state for GST calculation
# For Rajasthan-based business: "Rajasthan"
# Change to your state: "Maharashtra", "Delhi", "Karnataka", etc.
SELLER_STATE=Rajasthan

# ==================== URLs ====================
NEXT_PUBLIC_API_URL=http://localhost:6005
ALLOWED_ORIGINS=["http://localhost:6004","http://localhost:6005","http://127.0.0.1:6004","http://127.0.0.1:6005"]

# ==================== Meilisearch ====================
MEILI_MASTER_KEY=your_meili_master_key_here
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_API_KEY=your_meili_master_key_here

# ==================== Payment Gateways ====================
# Razorpay (Primary Payment Method - Razorpay-only deployment)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CHECKOUT_CONFIG_ID=  # Dashboard Payment Config ID (e.g. config_REDACTED) - enables UPI and configured methods

# Payment URLs
PAYMENT_SUCCESS_URL=http://localhost:6005/payment/success
PAYMENT_FAILURE_URL=http://localhost:6005/payment/failure
PAYMENT_NOTIFY_URL=http://localhost:6005/api/v1/webhooks/razorpay

# ==================== Email/SMTP ====================
# Hostinger Email Configuration
# CRITICAL: SMTP_TLS must be true for port 465 (SSL connection)
# Port 465 uses implicit SSL/TLS, while port 587 uses STARTTLS
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@aaryaclothing.in
SMTP_PASSWORD=your_hostinger_email_password
SMTP_TLS=true
EMAIL_FROM=noreply@aaryaclothing.in
EMAIL_FROM_NAME=Aarya Clothing

# ==================== WhatsApp Business API (Optional) ====================
# Leave empty to disable WhatsApp OTP (email-only mode)
# Get credentials from Meta Business Suite: https://business.facebook.com
# WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
# WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# WHATSAPP_ACCESS_TOKEN=your_access_token
# WHATSAPP_API_VERSION=v18.0

# ==================== OTP Settings ====================
OTP_CODE_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_MINUTES=1
OTP_MAX_RESEND_PER_HOUR=5

# ==================== Cloudflare R2 Storage ====================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=aarya-clothing-images
R2_PUBLIC_URL=
R2_REGION=auto

# ==================== AI Configuration ====================
# Google Gemini Flash (recommended — very cost-effective, free tier available)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
AI_MODEL=gemini-2.0-flash-lite           # cheapest model (gemini-2.0-flash for better quality)
AI_MAX_HISTORY=8                         # max messages in context (keep low for cost)
AI_CUSTOMER_MAX_TOKENS=512              # max output tokens for customer chat
AI_ADMIN_MAX_TOKENS=2048               # max output tokens for admin chat

# Optional: Additional AI providers (text-only mode, no tool support)
# Leave empty to use Gemini only
OPENAI_API_KEY=                         # OpenAI API key (sk-...)
GROQ_API_KEY=                           # Groq API key (gsk_...) - Free tier available
ANTHROPIC_API_KEY=                      # Anthropic API key (sk-ant-...)

# ==================== Service URLs (Internal Docker) ====================
CORE_SERVICE_URL=http://core:5001
COMMERCE_SERVICE_URL=http://commerce:5002
PAYMENT_SERVICE_URL=http://payment:5003
ADMIN_SERVICE_URL=http://admin:5004

# ==================== Cashfree Payment Gateway ====================
# Optional alternative to Razorpay
# Get credentials from: https://dashboard.cashfree.com
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_ENV=production  # Use "sandbox" for testing
