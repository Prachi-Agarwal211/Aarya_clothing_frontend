{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "PostgreSQL database: connections, queries, cache hits, locks, replication",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    { "asDropdown": true, "includeVars": false, "keepTime": true, "tags": ["aarya"], "title": "Aarya Dashboards", "type": "dashboards" }
  ],
  "panels": [
    {
      "title": "Database Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100
    },
    {
      "title": "Active Connections",
      "type": "stat",
      "id": 1,
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(pg_stat_activity_count)", "legendFormat": "connections" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 40 },
            { "color": "red", "value": 80 }
          ]}
        }
      },
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "title": "Max Connections",
      "type": "stat",
      "id": 2,
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "pg_settings_max_connections", "legendFormat": "max" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "colorMode": "value", "graphMode": "none" }
    },
    {
      "title": "Cache Hit Ratio",
      "type": "stat",
      "id": 3,
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(pg_stat_database_blks_hit) / (sum(pg_stat_database_blks_hit) + sum(pg_stat_database_blks_read)) * 100", "legendFormat": "hit%" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 90 },
            { "color": "green", "value": 95 }
          ]}
        }
      },
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "title": "DB Size",
      "type": "stat",
      "id": 4,
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "pg_database_size_bytes{datname=\"aarya_clothing\"}", "legendFormat": "size" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "title": "Transactions/sec",
      "type": "stat",
      "id": 5,
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(pg_stat_database_xact_commit[5m]) + rate(pg_stat_database_xact_rollback[5m])", "legendFormat": "tps" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "title": "Dead Tuples",
      "type": "stat",
      "id": 6,
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(pg_stat_user_tables_n_dead_tup)", "legendFormat": "dead tuples" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 10000 },
            { "color": "red", "value": 100000 }
          ]}
        }
      },
      "options": { "colorMode": "value", "graphMode": "area" }
    },

    {
      "title": "Connection Details",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 200
    },
    {
      "title": "Connections Over Time",
      "type": "timeseries",
      "id": 10,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(pg_stat_activity_count)", "legendFormat": "total connections" },
        { "expr": "pg_settings_max_connections", "legendFormat": "max connections" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "title": "Connections by State",
      "type": "timeseries",
      "id": 11,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(pg_stat_activity_count) by (state)", "legendFormat": "{{state}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "title": "Query Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 300
    },
    {
      "title": "Transactions (commit vs rollback)",
      "type": "timeseries",
      "id": 20,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(pg_stat_database_xact_commit[5m])", "legendFormat": "commits" },
        { "expr": "rate(pg_stat_database_xact_rollback[5m])", "legendFormat": "rollbacks" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "title": "Tuple Operations",
      "type": "timeseries",
      "id": 21,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(pg_stat_database_tup_inserted[5m])", "legendFormat": "inserts" },
        { "expr": "rate(pg_stat_database_tup_updated[5m])", "legendFormat": "updates" },
        { "expr": "rate(pg_stat_database_tup_deleted[5m])", "legendFormat": "deletes" },
        { "expr": "rate(pg_stat_database_tup_returned[5m])", "legendFormat": "returned" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "title": "Cache & I/O",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 400
    },
    {
      "title": "Cache Hit Ratio Over Time",
      "type": "timeseries",
      "id": 30,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(pg_stat_database_blks_hit) / (sum(pg_stat_database_blks_hit) + sum(pg_stat_database_blks_read)) * 100", "legendFormat": "hit ratio %" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list" } }
    },
    {
      "title": "Block I/O",
      "type": "timeseries",
      "id": 31,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(pg_stat_database_blks_hit[5m])", "legendFormat": "cache hits" },
        { "expr": "rate(pg_stat_database_blks_read[5m])", "legendFormat": "disk reads" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "title": "Locks & Conflicts",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 500
    },
    {
      "title": "Locks by Type",
      "type": "timeseries",
      "id": 40,
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(pg_locks_count) by (mode)", "legendFormat": "{{mode}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "title": "Temp File Creation (disk spillover)",
      "type": "timeseries",
      "id": 41,
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(pg_stat_database_temp_files[5m])", "legendFormat": "temp files/sec" },
        { "expr": "rate(pg_stat_database_temp_bytes[5m])", "legendFormat": "temp bytes/sec" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } }
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["aarya", "database", "postgresql"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "15s", "30s", "1m", "5m"] },
  "timezone": "browser",
  "title": "Database Overview",
  "uid": "aarya-database",
  "version": 1
}
