# Payment Service Environment Variables - Aarya Clothing
# Copy this file to .env and fill in your actual values

# ==================== Database ====================
DATABASE_URL=postgresql://aarya_user:password@localhost:5432/aarya_payment
REDIS_URL=redis://localhost:6379/0

# ==================== Common Settings ====================
SECRET_KEY=your-super-secret-key-here
DEBUG=true
LOG_LEVEL=info

# ==================== Razorpay Configuration ====================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ==================== Easebuzz Configuration ====================
EASEBUZZ_MERCHANT_KEY=your_easebuzz_merchant_key
EASEBUZZ_SALT=your_easebuzz_salt_key
EASEBUZZ_ENV=test
EASEBUZZ_WEBHOOK_SECRET=your_easebuzz_webhook_secret

# ==================== Payment Settings ====================
PAYMENT_TIMEOUT_SECONDS=300
MAX_RETRY_ATTEMPTS=3
PAYMENT_SUCCESS_URL=http://localhost:3000/payment/success
PAYMENT_FAILURE_URL=http://localhost:3000/payment/failure

# ==================== Service URLs ====================
CORE_SERVICE_URL=http://core:8001
COMMERCE_SERVICE_URL=http://commerce:8010

# ==================== CORS ====================
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# ==================== Monitoring ====================
SENTRY_DSN=your_sentry_dsn_here
